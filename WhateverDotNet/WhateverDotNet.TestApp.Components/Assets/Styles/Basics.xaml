<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- BASIC COLORS -->
    <Color x:Key="ErrorColor">#DA3B32</Color>
    <Color x:Key="WarningColor">#FB6944</Color>

    <Color x:Key="PureWhiteColor">#FFFFFF</Color>
    <Color x:Key="WhiteColor">#F0F6FC</Color>

    <Color x:Key="LightGrayColor">#C0C3C6</Color>
    <Color x:Key="RegularGrayColor">#646B71</Color>
    <Color x:Key="DarkGrayColor">#393D40</Color>

    <Color x:Key="RegularBlueColor">#326197</Color>
    <Color x:Key="DarkBlueColor">#023C7B</Color>
    <Color x:Key="SuperDarkBlueColor">#073E7C</Color>

    <sys:Double x:Key="CornerRadius_No_Value">0</sys:Double>
    <sys:Double x:Key="CornerRadius_Regular_Value">4</sys:Double>

    <Thickness x:Key="BorderThickness_No" Bottom="0" Left="0" Right="0" Top="0"/>
    <Thickness x:Key="BorderThickness_Tiny" Bottom="1" Left="1" Right="1" Top="1"/>

    <FontFamily x:Key="FontFamily_Regular">Rubik</FontFamily>

    <sys:Double x:Key="FontSize_Header">16</sys:Double>
    <sys:Double x:Key="FontSize_PageName">20</sys:Double>
    <sys:Double x:Key="FontSize_Regular">14</sys:Double>
    <sys:Double x:Key="FontSize_Small">12</sys:Double>
    <sys:Double x:Key="FontSize_Smaller">10</sys:Double>

    <!-- BUTTONS STYLES RESOURCE DICTIONARY -->
    <CornerRadius x:Key="CornerRadius_IconButton_Regular"
                  BottomLeft="{StaticResource CornerRadius_Regular_Value}"
                  BottomRight="{StaticResource CornerRadius_Regular_Value}"
                  TopLeft="{StaticResource CornerRadius_Regular_Value}"
                  TopRight="{StaticResource CornerRadius_Regular_Value}"/>
    <CornerRadius x:Key="CornerRadius_IconButton_No"
                  BottomLeft="{StaticResource CornerRadius_No_Value}"
                  BottomRight="{StaticResource CornerRadius_No_Value}"
                  TopLeft="{StaticResource CornerRadius_No_Value}"
                  TopRight="{StaticResource CornerRadius_No_Value}"/>

    <SolidColorBrush x:Key="Background_IconButton_DisabledBrush" Color="{StaticResource PureWhiteColor}"/>
    <SolidColorBrush x:Key="Background_IconButton_HighlightedBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="Background_IconButton_RegularBrush" Color="{StaticResource PureWhiteColor}"/>

    <SolidColorBrush x:Key="Foreground_IconButton_DisabledBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="Foreground_IconButton_HighlightedBrush" Color="{StaticResource DarkBlueColor}"/>
    <SolidColorBrush x:Key="Foreground_IconButton_RegularBrush" Color="{StaticResource RegularBlueColor}"/>
    <SolidColorBrush x:Key="Foreground_IconButton_RemoveHighlightedBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="Foreground_IconButton_RemoveRegularBrush" Color="{StaticResource ErrorColor}"/>

    <!-- TEXT STYLES RESOURCE DICTIONARY -->
    <SolidColorBrush x:Key="Background_Text_DisabledBrush" Color="{StaticResource PureWhiteColor}"/>
    <SolidColorBrush x:Key="Background_Text_HighlightedBrush" Color="{StaticResource PureWhiteColor}"/>
    <SolidColorBrush x:Key="Background_Text_RegularBrush" Color="{StaticResource PureWhiteColor}"/>

    <SolidColorBrush x:Key="Foreground_Text_DisabledBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="Foreground_Text_ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="Foreground_Text_LabelBrush" Color="{StaticResource RegularGrayColor}"/>
    <SolidColorBrush x:Key="Foreground_Text_PlaceholderBrush" Color="{StaticResource RegularGrayColor}"/>
    <SolidColorBrush x:Key="Foreground_Text_RegularBrush" Color="{StaticResource DarkGrayColor}"/>
    <SolidColorBrush x:Key="Foreground_Text_WarningBrush" Color="{StaticResource WarningColor}"/>

    <!-- BASIC BRUSHES -->
    <SolidColorBrush x:Key="ContrastBrush" Color="{StaticResource SuperDarkBlueColor}"/>
    
    <SolidColorBrush x:Key="BackgroundContrastBrush" Color="{StaticResource RegularBlueColor}"/>
    <SolidColorBrush x:Key="BackgroundDisabledBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="BackgroundHighlightedBrush" Color="{StaticResource WhiteColor}"/>
    <SolidColorBrush x:Key="BackgroundRegularBrush" Color="{StaticResource PureWhiteColor}"/>

    <SolidColorBrush x:Key="Border_DisabledBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="Border_ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="Border_HighlightedBrush" Color="{StaticResource DarkBlueColor}"/>
    <SolidColorBrush x:Key="Border_RegularBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="Border_WarningBrush" Color="{StaticResource WarningColor}"/>

    <SolidColorBrush x:Key="ForegroundButtonBrush" Color="{StaticResource RegularBlueColor}"/>
    <SolidColorBrush x:Key="ForegroundHighlightedButtonBrush" Color="{StaticResource DarkBlueColor}"/>
    <SolidColorBrush x:Key="ForegroundDisabledBrush" Color="{StaticResource LightGrayColor}"/>
    <SolidColorBrush x:Key="ForegroundErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="ForegroundLabelBrush" Color="{StaticResource RegularGrayColor}"/>
    <SolidColorBrush x:Key="ForegroundPlaceholderBrush" Color="{StaticResource RegularGrayColor}"/>
    <SolidColorBrush x:Key="ForegroundRegularBrush" Color="{StaticResource DarkGrayColor}"/>
    <SolidColorBrush x:Key="ForegroundWarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ForegroundWhiteBrush" Color="{StaticResource PureWhiteColor}"/>

    <!-- FONTS -->
    <FontFamily x:Key="RegularFontFamily">Rubik</FontFamily>

    <sys:Double x:Key="HeaderFontSize">16</sys:Double>
    <sys:Double x:Key="PageNameFontSize">28</sys:Double>
    <sys:Double x:Key="RegularFontSize">14</sys:Double>
    <sys:Double x:Key="SmallFontSize">12</sys:Double>
    <sys:Double x:Key="SmallerFontSize">10</sys:Double>

    <CornerRadius x:Key="RegularCornerRadius" BottomLeft="4" BottomRight="4" TopLeft="4" TopRight="4"/>
    
    <!-- ICONS -->
    <sys:Double x:Key="IconRegularSize">24</sys:Double>
    <sys:Double x:Key="IconSmallSize">20</sys:Double>
    
    <!-- TODO: REMOVE OBSOLETE ITEMS -->
    <FontFamily x:Key="PrimaryFontFamily">Rubik</FontFamily>
    <sys:Double x:Key="PrimaryFontSize">14</sys:Double>

    <!-- TODO: MOVE OUT THE FOLLOWING SECTION -->
    <!-- EDITABLE DATA GRID STYLES -->
    <Style x:Key="EditableDataGrid_TextBlock_Style"
           TargetType="{x:Type TextBlock}">
        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="FontFamily" Value="{DynamicResource RegularFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>

        <Setter Property="Foreground" Value="{DynamicResource ForegroundRegularBrush}"/>

        <Setter Property="Margin" Value="2"/>

        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditableDataGrid_TextBox_Style"
           TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="Transparent"/>

        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0 0 0 1"/>

        <Setter Property="FontFamily" Value="{DynamicResource RegularFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>

        <Setter Property="Foreground" Value="{DynamicResource ForegroundRegularBrush}"/>

        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="VerticalAlignment" Value="Center"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <Border x:Name="txtBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer 
                                x:Name="PART_ContentHost"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                Margin="0"
                                VerticalAlignment="Center"
                                VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="txtBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Border_HighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="txtBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Border_ErrorBrush}"/>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditableDataGrid_ComboBoxCell_BaseStyle"
           TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource BackgroundRegularBrush}"/>

        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0 0 0 1"/>

        <Setter Property="FontFamily" Value="{DynamicResource RegularFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>

        <Setter Property="Foreground" Value="{DynamicResource ForegroundRegularBrush}"/>

        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="EditableDataGrid_ComboBoxCell_ToggleButtonStyle"
           TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ClickMode" Value="Press"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsChecked" Value="{Binding
                                IsDropDownOpen,
                                Mode=TwoWay,
                                RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="Margin" Value="0 0 5 0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="cmbToggleButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Image x:Name="btnIcon"
                                   Grid.Column="0"
       
                                   HorizontalAlignment="Right"
                                   Height="16"
                                   Width="16"
                                   Source="/WhateverDotNet.TestApp.Components;component/Assets/Icons/angle_highlighted.png">
                                <Image.RenderTransform>
                                    <RotateTransform
                                        x:Name="tglIconRotateTransform"
                                        Angle="0"/>
                                </Image.RenderTransform>
                            </Image>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditableDataGrid_ComboBoxCell_ElementStyle"
           BasedOn="{StaticResource EditableDataGrid_ComboBoxCell_BaseStyle}"
           TargetType="{x:Type ComboBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Border>
                        <Grid>
                            <TextBlock 
                                x:Name="cmbTextBlock"
                                
                                Background="{TemplateBinding Background}"
                                
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="{TemplateBinding FontSize}"
                                FontStyle="{TemplateBinding FontStyle}"
                                FontWeight="{TemplateBinding FontWeight}"
                                
                                Foreground="{TemplateBinding Foreground}"
                                
                                Text="{TemplateBinding Text}"
                                
                                VerticalAlignment="Center"/>
                            <ToggleButton
                                x:Name="cmbToggleBtn"
                                
                                Background="AliceBlue"
                                Focusable="False"
                                IsHitTestVisible="True"
                                
                                Style="{StaticResource EditableDataGrid_ComboBoxCell_ToggleButtonStyle}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="EditableDataGrid_ComboBoxCell_EditingElementStyle"
           BasedOn="{StaticResource EditableDataGrid_ComboBoxCell_BaseStyle}"
           TargetType="{x:Type ComboBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <Border x:Name="cmbBorder">
                            <Grid SnapsToDevicePixels="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Style="{StaticResource EditableDataGrid_TextBlock_Style}"
                                    Text="{TemplateBinding Text}"/>

                                <Border Grid.Column="1"
                                        Grid.Row="0"
                                        
                                        Height="16"
                                        Width="16"
                                        Margin="0 0 6 0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        
                                        >
                                    <Path
    x:Name="tglIcon"

    Data="M0 0 16 16 0 0 8 11.207l-4-4V5.793l4 4 4-4v1.414 L8 11.207"
    Fill="{StaticResource ForegroundRegularBrush}"

    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"

    Stretch="Uniform"
    RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform
            x:Name="tglIconRotateTransform"
            Angle="180"/>
                                        </Path.RenderTransform>
                                    </Path>
                                </Border>
                            </Grid>
                        </Border>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               MinWidth="{Binding 
                                            ActualWidth,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PopupAnimation="Slide">
                            <Border x:Name="cmbPopupBorder"
                                    Background="{DynamicResource BackgroundRegularBrush}"
                                    BorderBrush="{DynamicResource BorderRegularBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource RegularCornerRadius}"
                                    Padding="2">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="False">
                            <Setter TargetName="tglIcon"
                                    Property="Data"
                                    Value="M 0 0 L -16 -16 L 0 0 L -8 -11.207 l 4 4 V -5.793 l -4 -4 l -4 4 v -1.414 L -8 -11.207"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>