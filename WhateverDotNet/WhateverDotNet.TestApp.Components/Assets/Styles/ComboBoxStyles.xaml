<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:converters="clr-namespace:WhateverDotNet.TestApp.Components.Converters"
                    xmlns:helpers="clr-namespace:WhateverDotNet.TestApp.Components.Helpers"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary>
            <converters:NegateConverter x:Key="NegateConverter"/>
        </ResourceDictionary>
        <ResourceDictionary Source="Basics.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <converters:TextToLabelVisibilityConverter x:Key="LabelVisibilityConverter"/>
    <converters:TextToPlaceholderVisibilityConverter x:Key="PlaceholderVisibilityConverter"/>

    <Style x:Key="BaseComboBoxItem"
           TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{DynamicResource PrimaryFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource PrimaryFontSize}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundRegularBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MultiSelectComboBoxItem"
           BasedOn="{StaticResource BaseComboBoxItem}"
           TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="cmbItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="{Binding Text}"
                                      IsChecked="{Binding IsSelected,
                                                          Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Margin="4 2"
                                      IsEnabled="{TemplateBinding IsEnabled}"/>
                        </StackPanel>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cmbItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource BackgroundHighlightedBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{TemplateBinding Foreground}"/>
                        </Trigger>
                        
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ForegroundDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StringComboBoxItem"
           BasedOn="{StaticResource BaseComboBoxItem}"
           TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="cmbItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter 
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cmbItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource BackgroundHighlightedBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ForegroundRegularBrush}"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="cmbItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource BackgroundHighlightedBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ForegroundRegularBrush}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource ForegroundDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BaseComboBoxToggleButton"
           TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ClickMode" Value="Press"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsChecked" Value="{Binding
                                        IsDropDownOpen,
                                        Mode=TwoWay,
                                        RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"/>
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="Margin" Value="0 0 5 0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="cmbToggleButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Path x:Name="cmbToggleButtonArrow"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{StaticResource ForegroundRegularBrush}"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BaseComboBox"
           TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource BackgroundRegularBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderRegularBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="FontFamily" Value="{DynamicResource PrimaryFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource PrimaryFontSize}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundRegularBrush}"/>

        <Setter Property="Height" Value="72.8"/>

        <Setter Property="Padding" Value="5.2 3.5"/>
        <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="MultiSelectComboBox"
           BasedOn="{StaticResource BaseComboBox}"
           TargetType="{x:Type ComboBox}">
        <Setter Property="ItemContainerStyle" Value="{StaticResource MultiSelectComboBoxItem}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>

                        <Label x:Name="cmbLabel"
                               Background="Transparent"
                               Content="{TemplateBinding Tag}"
                               Focusable="False"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource ForegroundLabelBrush}"
                               Grid.Row="0"
                               Margin="2 0 0 2"
                               Padding="5 2"
                               Visibility="{
                                    Binding Text,
                                    Converter={StaticResource LabelVisibilityConverter},
                                    Mode=OneWay,
                                    ElementName=PART_EditableTextBox}"/>

                        <Border x:Name="cmbBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Focusable="False"
                                Grid.Row="1">
                            <Grid>
                                <Label x:Name="cmbPlaceholder"
                                       Content="{TemplateBinding Tag}"
                                       Focusable="False"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{DynamicResource ForegroundPlaceholderBrush}"
                                       HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                       IsHitTestVisible="False"
                                       Margin="6 0 0 0"
                                       VerticalAlignment="Center"
                                       Visibility="{
                                             Binding Text,
                                             Converter={StaticResource PlaceholderVisibilityConverter},
                                             Mode=OneWay,
                                             ElementName=PART_EditableTextBox}"/>

                                <TextBox x:Name="PART_EditableTextBox"
                                         Background="Transparent"
                                         BorderBrush="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         HorizontalAlignment="Left"
                                         Margin="6 2 0 0"
                                         Text="{TemplateBinding Text}"
                                         VerticalAlignment="Center"/>

                                <ToggleButton x:Name="cmbToggleButton"
                                              Style="{DynamicResource BaseComboBoxToggleButton}"/>
                            </Grid>
                        </Border>

                        <Label x:Name="cmbMessage"
                               Focusable="False"
                               FontSize="{DynamicResource SmallFontSize}"
                               Grid.Row="2"
                               Margin="2 0 0 2"
                               Padding="0"
                               Visibility="Hidden"/>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               MinWidth="{Binding 
                                            ActualWidth,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PopupAnimation="Slide"
                               VerticalOffset="{Binding ActualHeight,
                                                    ElementName=cmbMessage,
                                                    Converter={StaticResource NegateConverter}}">
                            <Border x:Name="cmbPopupBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource BorderRegularBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="2">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding
                                                Items.Count,
                                                RelativeSource={RelativeSource Self}}"
                                     Value="0">
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderHighlightedBrush}"/>
                            <Setter TargetName="cmbLabel"
                                    Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="cmbPlaceholder"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderHighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderHighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderErrorBrush}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Content"
                                    Value="{Binding
                                        Path=(Validation.Errors)[0].ErrorContent,
                                        RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Foreground"
                                    Value="{DynamicResource ForegroundErrorBrush}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <DataTrigger Binding="{Binding
                                                Path=(helpers:ValidationHelper.HasWarning),
                                                RelativeSource={RelativeSource Self}}"
                                     Value="True">
                            <Setter TargetName="cmbMessage"
                                    Property="Content"
                                    Value="{Binding
                                            Path=(helpers:ValidationHelper.WarningContent),
                                            RelativeSource={RelativeSource Self}}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Foreground"
                                    Value="{DynamicResource ForegroundWarningBrush}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StringComboBox"
           BasedOn="{StaticResource BaseComboBox}"
           TargetType="{x:Type ComboBox}">
        <Setter Property="ItemContainerStyle" Value="{StaticResource StringComboBoxItem}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>

                        <Label x:Name="cmbLabel"
                               Background="Transparent"
                               Content="{TemplateBinding Tag}"
                               Focusable="False"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource ForegroundLabelBrush}"
                               Grid.Row="0"
                               Margin="2 0 0 2"
                               Padding="5 2"/>

                        <Border x:Name="cmbBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Focusable="False"
                                Grid.Row="1">
                            <Grid>
                                <Label x:Name="cmbPlaceholder"
                                       Content="{TemplateBinding Tag}"
                                       Focusable="False"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{DynamicResource ForegroundPlaceholderBrush}"
                                       HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                       IsHitTestVisible="False"
                                       Margin="6 0 0 0"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                                <TextBox x:Name="PART_EditableTextBox"
                                         Background="Transparent"
                                         BorderBrush="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         HorizontalAlignment="Left"
                                         Margin="6 2 0 0"
                                         Text="{TemplateBinding Text}"
                                         VerticalAlignment="Center"/>

                                <ToggleButton x:Name="cmbToggleButton"
                                              Style="{DynamicResource BaseComboBoxToggleButton}"/>
                            </Grid>
                        </Border>

                        <Label x:Name="cmbMessage"
                               Focusable="False"
                               FontSize="{DynamicResource SmallFontSize}"
                               Grid.Row="2"
                               Margin="2 0 0 2"
                               Padding="0"
                               Visibility="Hidden"/>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               MinWidth="{Binding 
                                            ActualWidth,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PopupAnimation="Slide"
                               VerticalOffset="{Binding ActualHeight,
                                                    ElementName=cmbMessage,
                                                    Converter={StaticResource NegateConverter}}">
                            <Border x:Name="cmbPopupBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource BorderRegularBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="2">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsFocused" Value="False"/>
                                <Condition Property="Text" Value="{x:Null}"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="cmbLabel"
                                    Property="Visibility"
                                    Value="Hidden"/>
                            <Setter TargetName="cmbPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </MultiTrigger>

                        <DataTrigger Binding="{Binding
                                                Items.Count,
                                                RelativeSource={RelativeSource Self}}"
                                     Value="0">
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding
                                                Items.Count,
                                                RelativeSource={RelativeSource Self}}"
                                     Value="1">
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderHighlightedBrush}"/>
                            <Setter TargetName="cmbLabel"
                                    Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="cmbPlaceholder"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderHighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderHighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="cmbLabel"
                                    Property="Visibility"
                                    Value="Hidden"/>
                            <Setter TargetName="cmbPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="Text" Value="">
                            <Setter TargetName="cmbLabel"
                                    Property="Visibility"
                                    Value="Hidden"/>
                            <Setter TargetName="cmbPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderErrorBrush}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Content"
                                    Value="{Binding
                                        Path=(Validation.Errors)[0].ErrorContent,
                                        RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Foreground"
                                    Value="{DynamicResource ForegroundErrorBrush}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <DataTrigger Binding="{Binding
                                                Path=(helpers:ValidationHelper.HasWarning),
                                                RelativeSource={RelativeSource Self}}"
                                     Value="True">
                            <Setter TargetName="cmbMessage"
                                    Property="Content"
                                    Value="{Binding
                                            Path=(helpers:ValidationHelper.WarningContent),
                                            RelativeSource={RelativeSource Self}}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Foreground"
                                    Value="{DynamicResource ForegroundWarningBrush}"/>
                            <Setter TargetName="cmbMessage"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>