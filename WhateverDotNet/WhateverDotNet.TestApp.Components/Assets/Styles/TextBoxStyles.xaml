<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:converters="clr-namespace:WhateverDotNet.TestApp.Components.Converters"
                    xmlns:helpers="clr-namespace:WhateverDotNet.TestApp.Components.Helpers"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Basics.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <converters:TextToLabelVisibilityConverter x:Key="LabelVisibilityConverter"/>
    <converters:TextToPlaceholderVisibilityConverter x:Key="PlaceholderVisibilityConverter"/>

    <Style x:Key="RegularTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource BackgroundRegularBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderRegularBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>

        <Setter Property="FontFamily" Value="{DynamicResource PrimaryFontFamily}"/>
        <Setter Property="FontSize" Value="{DynamicResource PrimaryFontSize}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>

        <Setter Property="Foreground" Value="{StaticResource ForegroundRegularBrush}"/>

        <Setter Property="Padding" Value="5.2 3.5"/>
        <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>

                        <Label x:Name="txtLabel"
                               Background="Transparent"
                               Content="{TemplateBinding Tag}"
                               Focusable="False"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource ForegroundLabelBrush}"
                               Grid.Row="0"
                               Margin="2 0 0 2"
                               Padding="5 2"
                               Visibility="{
                                    Binding Text,
                                    Converter={StaticResource LabelVisibilityConverter},
                                    Mode=OneWay,
                                    RelativeSource={RelativeSource AncestorType={x:Type TextBox}}}"/>

                        <Border x:Name="txtBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Grid.Row="1">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              VerticalScrollBarVisibility="Hidden"/>
                                <Label x:Name="txtPlaceholder"
                                       Content="{TemplateBinding Tag}"
                                       Focusable="False"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{DynamicResource ForegroundPlaceholderBrush}"
                                       HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                       IsHitTestVisible="False"
                                       Margin="10 0 0 0"
                                       Padding="0"
                                       VerticalAlignment="Center"
                                       VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                       Visibility="{
                                            Binding Text,
                                            Converter={StaticResource PlaceholderVisibilityConverter},
                                            Mode=OneWay,
                                            RelativeSource={RelativeSource AncestorType={x:Type TextBox}}}"/>
                            </Grid>
                        </Border>

                        <Label x:Name="txtMessage"
                               Focusable="False"
                               FontSize="{DynamicResource SmallFontSize}"
                               Grid.Row="2"
                               Padding="0"
                               Visibility="Hidden"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value=""/>
                                <Condition Property="IsFocused" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="txtPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </MultiTrigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="txtLabel"
                                    Property="Visibility"
                                    Value="Visible"/>
                            <Setter TargetName="txtPlaceholder"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter TargetName="txtBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderHighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="txtBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource BorderErrorBrush}"/>
                            <Setter TargetName="txtMessage"
                                    Property="Content"
                                    Value="{Binding
                                        Path=(Validation.Errors)[0].ErrorContent,
                                        RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="txtMessage"
                                    Property="Foreground"
                                    Value="{DynamicResource ForegroundErrorBrush}"/>
                            <Setter TargetName="txtMessage"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <DataTrigger Binding="{Binding
                                        Path=(helpers:ValidationHelper.HasWarning),
                                        RelativeSource={RelativeSource Self}}"
                                     Value="True">
                            <Setter TargetName="txtMessage"
                                    Property="Content"
                                    Value="{Binding
                                        Path=(helpers:ValidationHelper.WarningContent),
                                        RelativeSource={RelativeSource Self}}"/>
                            <Setter TargetName="txtMessage"
                                    Property="Foreground"
                                    Value="{DynamicResource ForegroundWarningBrush}"/>
                            <Setter TargetName="txtMessage"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>