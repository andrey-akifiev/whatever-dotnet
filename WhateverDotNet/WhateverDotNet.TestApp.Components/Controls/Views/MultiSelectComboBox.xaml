<UserControl x:Class="WhateverDotNet.TestApp.Components.Controls.Views.MultiSelectComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:WhateverDotNet.TestApp.Components.Helpers"
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Components.Controls.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <ComboBox
            IsEditable="True"
            IsReadOnly="True"
            ItemsSource="{Binding
                Path=Items,
                Mode=TwoWay,
                RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
            StaysOpenOnEdit="True"
            Style="{StaticResource MultiSelectComboBox}"
            Tag="{Binding
                Path=Tag,
                Mode=OneWay,
                RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
            Text="{Binding
                Path=DisplayText,
                Mode=OneWay,
                RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
            helpers:ValidationHelper.HasWarning="{Binding
                Path=HasWarning,
                Mode=OneWay,
                RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
            helpers:ValidationHelper.WarningContent="{Binding
                Path=WarningContent,
                Mode=OneWay,
                RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
    </Grid>
</UserControl>