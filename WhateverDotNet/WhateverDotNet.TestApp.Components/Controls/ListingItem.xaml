<UserControl x:Class="WhateverDotNet.TestApp.Components.Controls.ListingItem"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Components.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             mc:Ignorable="d"
             d:DesignHeight="100" d:DesignWidth="150">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="1"
                   Grid.Row="0"
                   FontSize="{DynamicResource RegularFontSize}"
                   FontWeight="Regular"
                   Margin="5"
                   Text="{Binding
                        Path=Title,
                        Mode=OneWay,
                        RelativeSource={RelativeSource AncestorType=local:ListingItem}}"/>
        <TextBlock Grid.Column="1"
                   Grid.Row="1"
                   FontSize="{DynamicResource SmallerFontSize}"
                   FontWeight="Regular"
                   Margin="5 0 5 5"
                   Text="{Binding
                        Path=Description,
                        Mode=OneWay,
                        RelativeSource={RelativeSource AncestorType=local:ListingItem}}"/>
    </Grid>
</UserControl>