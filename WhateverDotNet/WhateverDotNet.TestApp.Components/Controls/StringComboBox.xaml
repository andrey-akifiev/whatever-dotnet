<UserControl x:Class="WhateverDotNet.TestApp.Components.Controls.StringComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:commands="clr-namespace:WhateverDotNet.TestApp.Components.Commands"
             xmlns:converters="clr-namespace:WhateverDotNet.TestApp.Components.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:WhateverDotNet.TestApp.Components.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Components.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/ComboBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <commands:CopyToClipboardCommand x:Key="CopyToClipboardCommand"/>
            <converters:ClipboardFormatConverter x:Key="ClipboardFormatConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ComboBox
            ItemsSource="{Binding
                Path=Items,
                Mode=OneWay,
                RelativeSource={RelativeSource AncestorType={x:Type local:StringComboBox}}}"
            Margin="5 0 0 0"
            SelectedValue="{Binding
                Path=SelectedValue,
                Mode=TwoWay,
                RelativeSource={RelativeSource AncestorType={x:Type local:StringComboBox}}}"
            Style="{StaticResource StringComboBox}"
            Tag="{Binding
                Path=Tag,
                Mode=OneWay,
                RelativeSource={RelativeSource AncestorType={x:Type local:StringComboBox}}}"/>
        <Button x:Name="CopyButton"
                Command="{StaticResource CopyToClipboardCommand}"
                Grid.Column="1"
                Margin="5 0 5 0"
                Style="{DynamicResource IconButton}"
                Tag="copy"
                ToolTip="Copy value to clipboard">
            <Button.CommandParameter>
                <MultiBinding Converter="{StaticResource ClipboardFormatConverter}">
                    <Binding
                        Path="SelectedValue"
                        Mode="OneWay"
                        RelativeSource="{RelativeSource AncestorType={x:Type local:StringComboBox}}"/>
                    <Binding
                        Path="CopyToClipboardTemplate"
                        Mode="OneWay"
                        RelativeSource="{RelativeSource AncestorType={x:Type local:StringComboBox}}"/>
                </MultiBinding>
            </Button.CommandParameter>
            <Style TargetType="Button">
                <Style.Triggers>
                    <DataTrigger 
                        Binding="{
                            Binding CopyToClipboardEnabled,
                            Mode=OneWay,
                            RelativeSource={RelativeSource AncestorType={x:Type local:StringComboBox}}}"
                        Value="False">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Button>
    </Grid>
</UserControl>