<UserControl x:Class="WhateverDotNet.TestApp.Components.Controls.ListingPanel"
             x:Name="Root"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:controls="clr-namespace:WhateverDotNet.TestApp.Components.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="280">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- List item template: title, description, actions button with context menu (Clone, Remove) -->
            <DataTemplate x:Key="ListingItemTemplate">
                <Border Background="Transparent" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontFamily="{DynamicResource FontFamily_Regular}"
                                       FontSize="{DynamicResource FontSize_Regular}"
                                       Foreground="{DynamicResource Foreground_Text_RegularBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Description}"
                                       FontFamily="{DynamicResource FontFamily_Regular}"
                                       FontSize="{DynamicResource FontSize_Small}"
                                       Foreground="{DynamicResource Foreground_Text_LabelBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Width="28" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Actions"
                                VerticalAlignment="Center">
                            <Button.Content>
                                <Path Data="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"
                                      Fill="{DynamicResource Foreground_Text_LabelBrush}"
                                      Stretch="Uniform"/>
                            </Button.Content>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Clone" Command="{Binding CloneCommand}"/>
                                    <MenuItem Header="Remove" Command="{Binding RemoveCommand}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        BorderBrush="{DynamicResource Border_DisabledBrush}"
        BorderThickness="0 0 1 0">
        <Grid
            Background="{Binding Background,
                         Mode=OneWay,
                         RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:AddIconButton
                Grid.Row="0"

                Content="Add Specification"
                Command="{Binding AddCommand}"
                Margin="0 15 0 10"
                Size="14">
                <controls:AddIconButton.Style>
                    <Style TargetType="{x:Type controls:AddIconButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:AddIconButton.Style>
            </controls:AddIconButton>
           

            <ListBox Grid.Row="1"
                     BorderThickness="0"
                     Background="Transparent"
                     Button.Click="OnActionsButtonClick"
                     ItemTemplate="{StaticResource ListingItemTemplate}"
                     ItemsSource="{Binding ItemViewModels}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectedItem="{Binding SelectedItemViewModel, Mode=TwoWay}"
                     SelectionMode="Single">
                <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundHighlightedBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BackgroundHighlightedBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.Style>
                    <Style TargetType="{x:Type ListBox}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
            </ListBox>
            <controls:ExpandCollapseToggleButton
                Grid.Row="2"
            
                Background="{Binding Background,
                         Mode=OneWay,
                         RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                Foreground="{Binding Foreground,
                         Mode=OneWay,
                         RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                Margin="0,0,0,8"/>
        </Grid>
    </Border>
</UserControl>