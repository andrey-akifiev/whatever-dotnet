<UserControl x:Class="WhateverDotNet.TestApp.Components.Controls.CollapsiblePanel"
             x:Name="root"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Components.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border
            Grid.Column="0"
            Grid.Row="0"
            Cursor="Hand">
            <Border.InputBindings>
                <MouseBinding 
                    Command="{Binding ToggleExpandCommand}"
                    Gesture="LeftClick"/>
            </Border.InputBindings>

            <Grid>
                <ToggleButton Background="Transparent"
                              BorderBrush="Transparent"
                              ClickMode="Press"
                              Focusable="False"
                              IsChecked="{Binding IsExpanded, ElementName=root}"
                              HorizontalContentAlignment="Right"
                              Margin="0 0 5 0"
                              VerticalContentAlignment="Center">
                    <ToggleButton.Style>
                        <Style TargetType="{x:Type ToggleButton}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Image
                                            x:Name="icon"
                                            Height="24"
                                            RenderTransformOrigin="0.5 0.5"
                                            Source="/WhateverDotNet.TestApp.Components;component/Assets/Icons/direction.png"
                                            Width="24">
                                            <Image.RenderTransform>
                                                <RotateTransform Angle="180"/>
                                            </Image.RenderTransform>
                                            <Image.Style>
                                                <Style TargetType="{x:Type Image}">
                                                    <Style.Triggers>
                                                        

                                                        <DataTrigger
                Binding="{Binding IsExpanded, ElementName=root}"
                Value="False">
                                                            <!--<DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(Image.RenderTransform).(RotateTransform.Angle)"
                                To="0"
                                Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>-->
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>

                                        <ControlTemplate.Triggers>
                                            <DataTrigger 
                                                    Binding="{Binding IsExpanded, ElementName=root}"
                                                    Value="True">
                                                <Setter TargetName="icon" Property="Width" Value="50"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetProperty="(Image.RenderTransform).(RotateTransform.Angle)"
                                                                To="180"
                                                                Duration="0:0:0.2">
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>    
                                        
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                    
                </ToggleButton>

                <TextBlock
                    Margin="5"
                    Text="{Binding Header, ElementName=root}"
                    VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Column="0"
              Grid.Row="1">
            <Grid.Style>
                <Style TargetType="{x:Type Grid}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger
                                Binding="{Binding IsExpanded, ElementName=root}"
                                Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <ContentPresenter
                x:Name="content"
                Content="{Binding CollapsibleContent, ElementName=root}"
                Margin="8 4 8 8">
            </ContentPresenter>
        </Grid>
    </Grid>
</UserControl>