<UserControl x:Class="WhateverDotNet.TestApp.Components.Controls.NavigationPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Components.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:nav="clr-namespace:WhateverDotNet.TestApp.Components.Navigation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="200">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical"
                Background="{DynamicResource BackgroundRegularBrush}">
        <ListView 
            Background="{DynamicResource BackgroundContrastBrush}"
            BorderBrush="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding Pages}"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            SelectedItem="{Binding SelectedPage}">
            <d:ListView.ItemsSource>
                <x:Array Type="{x:Type nav:Page}">
                    <nav:Page Name="Report Comparison"/>
                    <nav:Page Name="Report Specifications"/>
                    <nav:Page Name="Simulations"/>
                </x:Array>
            </d:ListView.ItemsSource>
            <ListView.Resources>
                <Style TargetType="{x:Type ListViewItem}">
                    <Setter Property="Background" Value="{DynamicResource BackgroundContrastBrush}"/>

                    <Setter Property="FontFamily" Value="{DynamicResource PrimaryFontFamily}"/>
                    <Setter Property="FontSize" Value="{DynamicResource PrimaryFontSize}"/>
                    <Setter Property="FontStyle" Value="Normal"/>
                    <Setter Property="FontWeight" Value="Normal"/>

                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle x:Name="rectangle"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch"
                                               Stroke="Transparent"
                                               Fill="Transparent"
                                               Grid.ColumnSpan="2"/>
                                    <Ellipse Stroke="{Binding IconColor, Converter={StaticResource StringToSolidColorBrushConverter}}"
                                             Fill="{Binding IconColor, Converter={StaticResource StringToSolidColorBrushConverter}}"
                                             StrokeThickness="2"
                                             Height="38"
                                             Width="38"
                                             Margin="12,7.5,0,7.5"
                                             Grid.Column="0"/>
                                    <Image Height="24"
                                           Width="24"
                                           Source="{Binding IconPath}"
                                           Stretch="Fill"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           Margin="19,8.5,0,7.5"
                                           Grid.Column="0"/>
                                    <Label Content="{Binding Name}"
                                           ToolTip="{Binding Description}"
                                           IsEnabled="{Binding IsEnabled}"
                                           Foreground="{DynamicResource ForegroundWhiteBrush}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                           Margin="12,0,0,0"
                                           Grid.Column="1"/>
                                    <Path x:Name="triangle"
                                          Width="12"
                                          Height="12"
                                          Stretch="Fill"
                                          Stroke="{DynamicResource BackgroundHighlightedBrush}"
                                          Fill="{DynamicResource BackgroundHighlightedBrush}"
                                          Visibility="Hidden"
                                          Data="F1 M 287.328,237.333L 319.344,255.818L 319.344,218.849L 287.328,237.333 Z "
                                          HorizontalAlignment="Right"
                                          Grid.Column="1"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Fill" TargetName="rectangle" Value="{DynamicResource ContrastBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Fill" TargetName="rectangle" Value="{DynamicResource ContrastBrush}"/>
                                        <Setter Property="Visibility" TargetName="triangle" Value="Visible"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.Resources>
        </ListView>


    </StackPanel>
</UserControl>