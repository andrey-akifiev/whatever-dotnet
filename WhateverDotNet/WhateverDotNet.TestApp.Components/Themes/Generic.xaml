                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:CollapsibleListView}">
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThickness_No}"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CollapsibleListView}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Logo -->
                                <RowDefinition Height="Auto"/>
                                <!-- Title -->
                                <RowDefinition Height="Auto"/>
                                <!-- Content -->
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Logo -->
                            <Border
                                x:Name="logo"
                                Grid.Row="0"
                                
                                Focusable="False"
                                Height="100"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="200">
                                <ContentPresenter
                                    Content="{Binding Logo,
                                              Mode=OneWay,
                                              RelativeSource={RelativeSource AncestorType={x:Type controls:CollapsibleListView}}}"/>
                            </Border>
                            <TextBlock Grid.Row="1" Text="PEWPEW"/>
                            <ScrollViewer
                                Grid.Row="2"
                                Focusable="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Grid>
                        
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:CollapsiblePanel}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CollapsiblePanel}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ContentPresenter
                            x:Name="content"
                            
                            Grid.Row="0"
                            
                            Content="{TemplateBinding Content}"
                            Focusable="False"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            Margin="{TemplateBinding Padding}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Visibility="Visible"/>

                        <ToggleButton 
                            Grid.Row="1"
                            
                            Background="{TemplateBinding Background}"
                            Foreground="{TemplateBinding Foreground}"
                            IsChecked="{Binding IsCollapsed,
                                                Converter={StaticResource InverseBooleanConverter},
                                                Mode=OneWay,
                                                RelativeSource={RelativeSource AncestorType={x:Type controls:CollapsiblePanel}}}"
                            Style="{StaticResource ToggleButton_SidePanel_Style}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
