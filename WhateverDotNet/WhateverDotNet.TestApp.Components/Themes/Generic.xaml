                                    Fill="{Binding ColorMark,
                                                   Mode=OneWay,
                                                   RelativeSource={RelativeSource TemplatedParent}}"
                                    Focusable="False"
                                    Margin="0 0 5 0"
                                    SnapsToDevicePixels="True"
                                    Width="{Binding ColorMarkSize,
                                                   Mode=OneWay,
                                                   RelativeSource={RelativeSource TemplatedParent}}"/>
