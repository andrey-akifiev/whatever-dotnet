    <Style x:Key="ToggleButton_SidePanel_Style"
           TargetType="{x:Type ToggleButton}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="IsChecked" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border MinHeight="40">
                        <Grid SnapsToDevicePixels="False">
                            <Grid.ColumnDefinitions>
                                <!-- Text -->
                                <ColumnDefinition Width="*"/>
                                <!-- Toggle button -->
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="xpndrCaption"
                                Grid.Column="0"
                                
                                FontFamily="{StaticResource FontFamily_Regular}"
                                FontSize="{StaticResource FontSize_Header}"
                                FontStyle="Normal"
                                FontWeight="Regular"
                                
                                Foreground="{TemplateBinding Foreground}"
                                
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Text="Collapse"/>
                            <Border
                                Grid.Column="1"
                
                                Margin="5 0 0 0"
                                Height="{StaticResource IconRegularSize}"
                                Width="{StaticResource IconRegularSize}">

                                <Path x:Name="xpndrTglIcon"
                                      Data="M0 0 16 16 0 0 8 11.207l-4-4V5.793l4 4 4-4v1.414 L8 11.207"
                                      Fill="{TemplateBinding Foreground}"
                          
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                          
                                      Stretch="Uniform"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform
                                            x:Name="xpndrTglIcon_RotateTransform"
                                            Angle="270"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Border>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="xpndrCaption"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsChecked"
                                 Value="False">
                            <Setter TargetName="xpndrCaption"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>
                        <!-- Animations on expand -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="xpndrTglIcon_RotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="270"
                                            To="90"
                                            Duration="0:0:0.2">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="xpndrTglIcon_RotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="90"
                                            To="270"
                                            Duration="0:0:0.2">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:CollapsibleListViewItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="2 2 2 2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CollapsibleListViewItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Icon -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Text -->
                            <ColumnDefinition Width="*"/>
                            <!-- Actions -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Selected icon -->
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Icon -->
                        <Border
                            x:Name="icon"
                            Grid.Column="0"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            
                            Height="{DynamicResource IconRegularSize}"
                            Width="{DynamicResource IconRegularSize}"
                            VerticalAlignment="Center">
                            <Path
                                Data="{Binding Icon}"
                                Fill="{TemplateBinding Foreground}"
                                Stretch="Uniform"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Visible"/>
                            <!--<ContentPresenter Content="{Binding Icon,
                                                        Mode=OneWay,
                                                        RelativeSource={RelativeSource AncestorType={x:Type controls:CollapsibleListViewItem}}}"/>-->
                        </Border>

                        <!-- Text -->
                        <TextBlock
                            x:Name="title"
                            Grid.Column="1"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            
                            Background="{TemplateBinding Background}"
                            FontFamily="{DynamicResource FontFamily_Regular}"
                            FontSize="{DynamicResource FontSize_Regular}"
                            FontStyle="Normal"
                            FontWeight="Regular"
                            Foreground="{TemplateBinding Foreground}"
                            Margin="5 2 2 2"
                            
                            Text="{Binding Title}"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center"
                            Visibility="Visible"/>
                        <TextBlock
                            x:Name="description"
                            Grid.Column="1"
                            Grid.Row="1"
    
                            Background="{TemplateBinding Background}"
                            FontFamily="{DynamicResource FontFamily_Regular}"
                            FontSize="{DynamicResource FontSize_Small}"
                            FontStyle="Normal"
                            FontWeight="Regular"
                            Foreground="{TemplateBinding Foreground}"
                            Margin="5 2 2 2"
    
                            Text="{Binding Description,
                                   Mode=OneWay,
                                   RelativeSource={RelativeSource AncestorType={x:Type controls:CollapsibleListViewItem}}}"
                            TextTrimming="CharacterEllipsis"
                            Visibility="Visible"/>
                        
                        <!-- Actions -->
                        <StackPanel
                            Grid.Column="2"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            
                            Background="{TemplateBinding Background}"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="5 0 5 0">
                        </StackPanel>

                        <!-- Selected icon -->
                        <Border
                            x:Name="selectedIcon"
                            Grid.Column="3"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Margin="2 2 2 5"
                            
                            Height="8"
                            Width="8"
                            VerticalAlignment="Center"
                            Visibility="Visible">
                            <Path
                                Data="M23.705 20.087 14.212 1.366C13.785.523 12.938 0 12 0s-1.786.523-2.212 1.365L.295 20.087a2.69 2.69 0 0 0 .107 2.642A2.64 2.64 0 0 0 2.666 24h18.667c.929 0 1.775-.476 2.264-1.271a2.69 2.69 0 0 0 .107-2.642Zm-.959 2.118a1.65 1.65 0 0 1-1.412.795H2.667a1.65 1.65 0 0 1-1.412-.795 1.7 1.7 0 0 1-.068-1.665l9.492-18.723C10.939 1.305 11.432 1 12 1s1.061.306 1.321.818l9.492 18.722a1.69 1.69 0 0 1-.068 1.665Z"
                                Fill="{TemplateBinding Foreground}"
                                Stretch="Uniform"/>
                        </Border>
                    </Grid>

                    <!--<ControlTemplate.Triggers>
                        <Trigger Property="Icon"
                                 Value="{x:Null}">
                            <Setter TargetName="icon"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>

