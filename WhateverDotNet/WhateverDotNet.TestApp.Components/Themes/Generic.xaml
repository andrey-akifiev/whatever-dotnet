    <!-- COMBO BOXES STYLES -->
    <Style x:Key="ToggleButton_ComboBox_Regular"
           TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>

        <Setter Property="ClickMode" Value="Press"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsChecked"
                Value="{Binding
                        IsDropDownOpen,
                        Mode=TwoWay,
                        RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"/>

        <Setter Property="HorizontalContentAlignment" Value="Right"/>

        <Setter Property="Margin" Value="0 0 5 0"/>

        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="cmbToggleButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Path x:Name="cmbTglIcon"
                                Data="M0 0 16 16 0 0 8 11.207l-4-4V5.793l4 4 4-4v1.414 L8 11.207"
                                Fill="{StaticResource ForegroundRegularBrush}"
          
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
          
                                Stretch="Uniform"
                                RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform
                                    x:Name="cmbTglIcon_RotateTransform"
                                    Angle="0"/>
                            </Path.RenderTransform>
                        </Path>
                    </Border>


                    <ControlTemplate.Triggers>
                        <!-- Animations on expand -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="cmbTglIcon_RotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="180"
                                            Duration="0:0:0.2">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="cmbTglIcon_RotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="180"
                                            To="0"
                                            Duration="0:0:0.2">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComboBoxItem_CommonStyle"
           TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily_Regular}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Regular}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource Foreground_Text_RegularBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="8 4"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ComboBoxItem_String"
           BasedOn="{StaticResource ComboBoxItem_CommonStyle}"
           TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="cmbItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter 
                            Content="{TemplateBinding Content}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="cmbItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource Background_Text_HighlightedBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Foreground_Text_RegularBrush}"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="cmbItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource Background_Text_HighlightedBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Foreground_Text_RegularBrush}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Foreground_Text_DisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ComboBox_CommonStyle"
           TargetType="{x:Type controls:BaseComboBox}">
        <Setter Property="Background" Value="{DynamicResource Background_Text_RegularBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Border_RegularBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThickness_Tiny}"/>

        <Setter Property="FontFamily" Value="{DynamicResource FontFamily_Regular}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Regular}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>

        <Setter Property="Foreground" Value="{DynamicResource Foreground_Text_RegularBrush}"/>

        <Setter Property="MinHeight" Value="12"/>

        <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>

        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style TargetType="{x:Type controls:SimplifiedComboBox}"
           BasedOn="{StaticResource ComboBox_CommonStyle}">
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0 0 0 1"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItem_String}"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SimplifiedComboBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="{TemplateBinding MinHeight}"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="cmbBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource CornerRadius_IconButton_No}"
                                Grid.Row="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/> <!-- Dropdown -->
                                    <ColumnDefinition Width="Auto"/> <!-- Actions -->
                                </Grid.ColumnDefinitions>
                                <Label x:Name="cmbPlaceholder"
                                       Grid.Column="0"
                                       Background="Transparent"
                                       Content="{TemplateBinding PlaceholderValue}"
                                       Focusable="False"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{DynamicResource Foreground_Text_PlaceholderBrush}"
                                       HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                       IsHitTestVisible="False"
                                       Margin="6 0 0 0"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                                <TextBox x:Name="PART_EditableTextBox"
                                         Grid.Column="0"
                                         Background="Transparent"
                                         BorderBrush="Transparent"
                                         BorderThickness="0"
                                         IsReadOnly="True"
                                         HorizontalAlignment="Left"
                                         Margin="6 2 0 0"
                                         Text="{TemplateBinding Text}"
                                         VerticalAlignment="Center"/>

                                <ToggleButton x:Name="cmbToggleButton"
                                              Grid.Column="0"
                                              Style="{StaticResource ToggleButton_ComboBox_Regular}"/>

                                <StackPanel 
                                        Grid.Column="1"
                                        Orientation="Horizontal">
                                    <controls:UndoIconButton
                                            x:Name="btnRevert"
                                            Command="{Binding RevertValueCommand,
                                                              Mode=OneWay,
                                                              RelativeSource={RelativeSource AncestorType={x:Type controls:BaseComboBox}}}"
                                            Focusable="False"
                                            Margin="2 0 2 0"
                                            Size="10"
                                            Visibility="Collapsed"/>

                                        <controls:ClearIconButton
                                            x:Name="btnClear"
                                            Command="{Binding ClearValueCommand,
                                                              Mode=OneWay,
                                                              RelativeSource={RelativeSource AncestorType={x:Type controls:BaseComboBox}}}"
                                            Focusable="False"
                                            Margin="2 0 2 0"
                                            Size="10"
                                            Style="{DynamicResource ClearIconButton_EmbeddedStyle}"
                                            Visibility="Collapsed"/>

                                        <controls:CopyIconButton
                                            x:Name="btnCopy"
                                            Focusable="False"
                                            Margin="2 0 2 0"
                                            Size="10"
                                            Visibility="Collapsed">
                                            <Button.CommandParameter>
                                                <MultiBinding Converter="{StaticResource ClipboardFormatConverter}">
                                                    <Binding Path="SelectedItem"
                                                             Mode="OneWay"
                                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:BaseComboBox}}"/>
                                                    <Binding Path="CopyToClipboardFormat"
                                                             Mode="OneWay"
                                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:BaseComboBox}}"/>
                                                </MultiBinding>
                                            </Button.CommandParameter>
                                        </controls:CopyIconButton>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{Binding IsDropDownOpen,
                                                Mode=TwoWay,
                                                RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown"
                                  MinWidth="{Binding ActualWidth,
                                                     RelativeSource={RelativeSource TemplatedParent}}"
                                  MaxHeight="{Binding MaxDropDownHeight,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <Border x:Name="cmbPopupBorder"
                                        Background="{DynamicResource Background_Text_RegularBrush}"
                                        BorderBrush="{DynamicResource Border_RegularBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource RegularCornerRadius}"
                                        Padding="2">
                                    <ScrollViewer x:Name="cmbPopupScrollViewer" VerticalScrollBarVisibility="Hidden">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowCopy" Value="True">
                            <Setter TargetName="btnCopy"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="ShowClear" Value="True">
                            <Setter TargetName="btnClear"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="ShowRevert" Value="True">
                            <Setter TargetName="btnRevert"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>
                        
                        <Trigger Property="SelectedItem" Value="{x:Null}">
                            <Setter TargetName="btnClear"
                                    Property="IsEnabled"
                                    Value="False"/>
                            <Setter TargetName="cmbPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="cmbPlaceholder"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Border_HighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="cmbBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Border_ErrorBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- EXPANDERS STYLES -->
    <!-- Styles for original Expander: https://learn.microsoft.com/en-us/dotnet/desktop/wpf/controls/expander-styles-and-templates?redirectedfrom=MSDN-->
    <Style x:Key="ToggleButton_Expander_DownStyle"
           TargetType="{x:Type controls:ExpanderToggleButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ExpanderToggleButton}">
                    <Border>
                        <Grid SnapsToDevicePixels="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Color mark -->
                                <ColumnDefinition Width="Auto"/> <!-- Toggle button -->
                                <ColumnDefinition Width="*"/> <!-- Content -->
                            </Grid.ColumnDefinitions>

                            <Rectangle
                                x:Name="xpndrColorMark"
                                Grid.Column="0"
                                Fill="{Binding ColorMark,
                                               Mode=OneWay,
                                               RelativeSource={RelativeSource TemplatedParent}}"
                                Margin="0 0 5 0"
                                Width="{Binding ColorMarkSize,
                                                Mode=OneWay,
                                                RelativeSource={RelativeSource TemplatedParent}}"
                                Focusable="False"
                                SnapsToDevicePixels="True"/>

                            <Border
                                Grid.Column="1"
                                
                                Margin="5 0 0 0"
                                Height="{DynamicResource IconSmallSize}"
                                Width="{DynamicResource IconSmallSize}">

                                <Path x:Name="xpndrTglIcon"
                                      Data="M0 0 16 16 0 0 8 11.207l-4-4V5.793l4 4 4-4v1.414 L8 11.207"
                                      Fill="{StaticResource ForegroundRegularBrush}"
                                          
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          
                                      Stretch="Uniform"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform
                                            x:Name="xpndrTglIcon_RotateTransform"
                                            Angle="0"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Border>

                            <ContentPresenter
                                x:Name="xpndrTitle"
                                
                                Grid.Column="2"
                                
                                HorizontalAlignment="Stretch"
                                Margin="4 0 0 0"
                                RecognizesAccessKey="True"
                                SnapsToDevicePixels="True"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hide Color Mark if not set -->
                        <Trigger Property="ColorMark" Value="{x:Null}">
                            <Setter TargetName="xpndrColorMark"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>
                        
                        <!-- Animations on expand -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="xpndrTglIcon_RotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="180"
                                            Duration="0:0:0.2">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="xpndrTglIcon_RotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="180"
                                            To="0"
                                            Duration="0:0:0.2">
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:ColoredExpanderPanel}">
        <Setter Property="Background" Value="{DynamicResource BackgroundRegularBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThickness_Tiny}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="10 10 0 10"/>

