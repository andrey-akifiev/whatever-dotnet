                    xmlns:controls="clr-namespace:WhateverDotNet.TestApp.Components.Controls"
                    xmlns:converters="clr-namespace:WhateverDotNet.TestApp.Components.Converters">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <commands:CopyToClipboardCommand x:Key="CopyToClipboardCommand"/>

    <converters:ClipboardFormatConverter x:Key="ClipboardFormatConverter"/>
    <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    <converters:IsNullToBooleanConverter x:Key="IsNullToBooleanConverter"/>
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>

    <!-- ICON BUTTONS STYLES -->
    <Style TargetType="{x:Type controls:BaseIconButton}">
        <Setter Property="Background" Value="{DynamicResource Background_IconButton_RegularBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThickness_No}"/>

        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground"
                Value="{Binding CustomForeground,
                                RelativeSource={RelativeSource Self},
                                TargetNullValue={StaticResource Foreground_IconButton_RegularBrush}}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BaseIconButton}">
                    <Border x:Name="btnBorder"
                            
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            
                            CornerRadius="{DynamicResource CornerRadius_IconButton_No}">
                        <Grid 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="btnIconHost"
                                  Grid.Column="0"  
                                  VerticalAlignment="Center">

                                <Path x:Name="btnIcon"
                                      Data="{TemplateBinding IconData}"
                                      Fill="{TemplateBinding Foreground}"
                                      Stretch="Uniform"/>
                            </Grid>
                            
                            <ContentPresenter 
                                x:Name="btnContent"
                                
                                Content="{TemplateBinding Content}"
                                
                                Grid.Column="1"
                                Margin="6 0 0 0"
                                
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                
                                RecognizesAccessKey="True"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Don't show content if it's not explicitly set up -->
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="btnContent"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>

                        <!-- Rearrange Icon according to IconPosition dependency property -->
                        <Trigger Property="IconPosition" Value="Right">
                            <Setter TargetName="btnIconHost"
                                    Property="Grid.Column"
                                    Value="1"/>
                            <Setter TargetName="btnContent"
                                    Property="Grid.Column"
                                    Value="0"/>
                            <Setter TargetName="btnContent"
                                    Property="Margin"
                                    Value="0 0 6 0"/>
                        </Trigger>

                        <!-- Change visual state based on accessibility props and button kind -->
                        <Trigger Property="Kind" Value="Remove">
                            <Setter Property="Foreground"
                                    Value="{Binding CustomForeground,
                                                    RelativeSource={RelativeSource Self},
                                                    TargetNullValue={StaticResource Foreground_IconButton_RemoveRegularBrush}}"/>
                        </Trigger>
                        
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Kind" Value="Regular"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground"
                                    Value="{Binding CustomHighlightedForeground,
                                                    RelativeSource={RelativeSource Self},
                                                    TargetNullValue={StaticResource Foreground_IconButton_HighlightedBrush}}"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="Kind" Value="Remove"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground"
                                    Value="{Binding CustomHighlightedForeground,
                                                    RelativeSource={RelativeSource Self},
                                                    TargetNullValue={StaticResource Foreground_IconButton_RemoveHighlightedBrush}}"/>
                        </MultiTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background"
                                    Value="{DynamicResource Background_IconButton_DisabledBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource Foreground_IconButton_DisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

