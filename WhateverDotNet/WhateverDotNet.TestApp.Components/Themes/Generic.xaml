    <Style TargetType="{x:Type controls:RegularTextBox}"
           BasedOn="{StaticResource TextBox_CommonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:RegularTextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <controls:LabeledTextBox
                            x:Name="txtInput"
                    
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                    
                            Grid.Row="0"
                    
                            LabelValue=
                                "{Binding LabelValue,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            OriginalValue=
                                "{Binding OriginalValue,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            PlaceholderValue=
                                "{Binding PlaceholderValue,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            ShowClear=
                                "{Binding ShowClear,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            ShowCopy=
                                "{Binding ShowCopy,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            ShowPlaceholder=
                                "{Binding ShowPlaceholder,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            ShowRevert=
                                "{Binding ShowRevert,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            Text=
                                "{Binding Text,
                                          Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"
                            TextMargin=
                                "{Binding TextMargin,
                                          Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:RegularTextBox}}}"/>

                        <controls:ErrorTextLabel
                            x:Name="txtMessage"
                            Grid.Row="1"
                            Visibility="Hidden"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="txtMessage"
                                    Property="Content"
                                    Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Setter TargetName="txtMessage"
                                    Property="Foreground"
                                    Value="{DynamicResource Foreground_Text_ErrorBrush}"/>
                            <Setter TargetName="txtMessage"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
