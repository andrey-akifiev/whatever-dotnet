    <!-- Expand/collapse toggle (HamburgerMenu, ListingPanel) -->
    <Style TargetType="{x:Type controls:ExpandCollapseToggleButton}">
        <Setter Property="Background" Value="{DynamicResource BackgroundContrastBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundWhiteBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ExpandCollapseToggleButton}">
                    <Border x:Name="tglBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Height="44">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Fill="Transparent"/>
                            <TextBlock x:Name="tglLblCollapse"
                                       Grid.Column="1"
                                       FontFamily="{DynamicResource FontFamily_Regular}"
                                       FontSize="{DynamicResource FontSize_Regular}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Margin="5,0,0,0"
                                       Text="Collapse"
                                       Visibility="Visible"
                                       VerticalAlignment="Center"/>
                            <Path x:Name="ToggleIcon"
                                  Grid.Column="2"
                                  Data="M.614.891a.047.047 0 0 1-.033-.08L.797.596a.047.047 0 0 0 0-.067L.581.314a.047.047 0 0 1 0-.067.047.047 0 0 1 .066 0l.215.215a.14.14 0 0 1 0 .199L.647.876A.05.05 0 0 1 .614.89M.286.891a.047.047 0 0 1-.033-.08L.501.563.253.315a.047.047 0 0 1 0-.067.047.047 0 0 1 .066 0L.6.529a.047.047 0 0 1 0 .067L.319.877a.05.05 0 0 1-.033.014"
                                  Fill="{TemplateBinding Foreground}"
                                  Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="ToggleIconRotate" Angle="180"/>
                                </Path.RenderTransform>
                            </Path>
                            <Rectangle Grid.Column="3" Fill="Transparent"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="tglLblCollapse" Property="Visibility" Value="Collapsed"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ToggleIconRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="180" To="0"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ToggleIconRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="180"
                                                         Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tglBorder" Property="Background" Value="{DynamicResource ContrastBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- LABELS STYLES -->
    <Style TargetType="{x:Type controls:BaseLabel}">
        <Setter Property="Background" Value="{DynamicResource Background_Text_RegularBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThickness_No}"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily_Regular}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Regular}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground_Text_RegularBrush}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BaseLabel}">
                    <TextBlock 
                        Background="{TemplateBinding Background}"
                        
                        Focusable="{TemplateBinding Focusable}"
                        
                        FontFamily="{TemplateBinding FontFamily}"
                        FontSize="{TemplateBinding FontSize}"
                        Foreground="{TemplateBinding Foreground}"
                        
                        Text="{TemplateBinding Content}"
                        
                        Visibility="{TemplateBinding Visibility}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:PlaceholderLabel}"
           BasedOn="{StaticResource {x:Type controls:BaseLabel}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Regular}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground_Text_PlaceholderBrush}"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Margin" Value="10 0 0 0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="{x:Type controls:TextLabel}"
           BasedOn="{StaticResource {x:Type controls:BaseLabel}}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Small}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground_Text_LabelBrush}"/>

        <Setter Property="Margin" Value="2 0 0 2"/>
        <Setter Property="Padding" Value="5 2"/>
    </Style>

    <Style TargetType="{x:Type controls:ErrorTextLabel}"
           BasedOn="{StaticResource {x:Type controls:BaseLabel}}">
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Small}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground_Text_ErrorBrush}"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- TEXT BLOCKS STYLES -->
    <Style TargetType="{x:Type controls:BaseTextBlock}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontFamily" Value="{DynamicResource FontFamily_Regular}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Regular}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>

        <Setter Property="Foreground" Value="{DynamicResource Foreground_Text_RegularBrush}"/>

        <Setter Property="Margin" Value="2"/>

        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="{x:Type controls:SimplifiedTextBlock}"
           BasedOn="{StaticResource {x:Type controls:BaseTextBlock}}">
        <Setter Property="Margin" Value="2"/>
    </Style>
    
    <!-- TEXT BOXES STYLES -->
    <Style x:Key="TextBox_CommonStyle"
           TargetType="{x:Type controls:BaseTextBox}">
        <Setter Property="Background" Value="{DynamicResource Background_Text_RegularBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Border_RegularBrush}"/>
        <Setter Property="BorderThickness" Value="{DynamicResource BorderThickness_Tiny}"/>

        <Setter Property="FontFamily" Value="{DynamicResource FontFamily_Regular}"/>
        <Setter Property="FontSize" Value="{DynamicResource FontSize_Regular}"/>
        <Setter Property="FontStyle" Value="Normal"/>
        <Setter Property="FontWeight" Value="Normal"/>

        <Setter Property="Foreground" Value="{DynamicResource Foreground_Text_RegularBrush}"/>

        <Setter Property="MinHeight" Value="30"/>

        <Setter Property="ScrollViewer.PanningMode" Value="VerticalFirst"/>
        <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>

        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BaseTextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="{TemplateBinding MinHeight}"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="txtBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource CornerRadius_IconButton_Regular}"
                                Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="5"/>
                                    <!-- Margin from right border -->
                                </Grid.ColumnDefinitions>

                                <ScrollViewer x:Name="PART_ContentHost"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              Margin="{Binding TextMargin,
                                                               Mode=OneWay,
                                                               RelativeSource={RelativeSource AncestorType={x:Type controls:BaseTextBox}}}"
                                              VerticalAlignment="Center"
                                              VerticalScrollBarVisibility="Hidden"/>
                                <controls:PlaceholderLabel
                                    x:Name="txtPlaceholder"
                                    FontSize="{TemplateBinding FontSize}"
                                    Content="{Binding PlaceholderValue,
                                                      Mode=OneWay,
                                                      RelativeSource={RelativeSource AncestorType={x:Type controls:BaseTextBox}}}"
                                    Margin="{Binding TextMargin,
                                                     Mode=OneWay,
                                                     RelativeSource={RelativeSource AncestorType={x:Type controls:BaseTextBox}}}"
                                    Visibility="Collapsed"/>

                                <controls:UndoIconButton
                                    x:Name="btnRevert"
                                    Command="{Binding RevertValueCommand,
                                                      Mode=OneWay,
                                                      RelativeSource={RelativeSource AncestorType={x:Type controls:BaseTextBox}}}"
                                    Focusable="False"
                                    Grid.Column="1"
                                    Margin="2 0 2 0"
                                    Size="10"
                                    Visibility="Collapsed"/>

                                <controls:ClearIconButton
                                    x:Name="btnClear"
                                    Command="{Binding ClearValueCommand,
                                                      Mode=OneWay,
                                                      RelativeSource={RelativeSource AncestorType={x:Type controls:BaseTextBox}}}"
                                    Focusable="False"
                                    Grid.Column="2"
                                    Margin="2 0 2 0"
                                    Size="10"
                                    Style="{DynamicResource ClearIconButton_EmbeddedStyle}"
                                    Visibility="Collapsed"/>

                                <controls:CopyIconButton
                                    x:Name="btnCopy"
                                    Focusable="False"
                                    Grid.Column="3"
                                    Margin="2 0 2 0"
                                    Size="10"
                                    Visibility="Collapsed">
                                    <Button.CommandParameter>
                                        <MultiBinding Converter="{StaticResource ClipboardFormatConverter}">
                                            <Binding Path="Text"
                                                     Mode="OneWay"
                                                     RelativeSource="{RelativeSource AncestorType={x:Type controls:BaseTextBox}}"/>
                                            <Binding Path="CopyToClipboardFormat"
                                                     Mode="OneWay"
                                                     RelativeSource="{RelativeSource AncestorType={x:Type controls:BaseTextBox}}"/>
                                        </MultiBinding>
                                    </Button.CommandParameter>
                                </controls:CopyIconButton>
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Show Parts depending on depprops -->
                        <Trigger Property="ShowCopy" Value="True">
                            <Setter TargetName="btnCopy"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <!-- Show Parts depending on state and depprops -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowClear" Value="True"/>
                                <Condition Property="IsFocused" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="btnClear"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ShowRevert" Value="True"/>
                                <Condition Property="IsFocused" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="btnRevert"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </MultiTrigger>

                        <!-- Show Parts depending on state -->
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="btnClear"
                                    Property="IsEnabled"
                                    Value="False"/>
                            <Setter TargetName="txtPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <Trigger Property="Text" Value="">
                            <Setter TargetName="btnClear"
                                    Property="IsEnabled"
                                    Value="False"/>
                            <Setter TargetName="txtPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value=""/>
                                <Condition Property="IsFocused" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="txtPlaceholder"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </MultiTrigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="txtPlaceholder"
                                    Property="Visibility"
                                    Value="Collapsed"/>
                            <Setter TargetName="txtBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Border_HighlightedBrush}"/>
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="txtBorder"
                                    Property="BorderBrush"
                                    Value="{DynamicResource Border_ErrorBrush}"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:BaseTextBox}"
           BasedOn="{StaticResource TextBox_CommonStyle}">
    </Style>

    <Style TargetType="{x:Type controls:LabeledTextBox}"
           BasedOn="{StaticResource TextBox_CommonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:LabeledTextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <controls:TextLabel
                            x:Name="txtLabel"
                            Grid.Row="0"
                            Margin="5 0 0 2"
                            Visibility="Visible">
                            <!-- TODO: this binding part is not finished. The original idea is to take Placeholder value if Label value is null or empty -->
                            <controls:TextLabel.Content>
                                <PriorityBinding FallbackValue="defaultvalue">
                                    <Binding Path="LabelValue"
                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:LabeledTextBox}}"/>
                                    <Binding Path="PlaceholderValue"
                                             RelativeSource="{RelativeSource AncestorType={x:Type controls:LabeledTextBox}}"/>
                                </PriorityBinding>
                            </controls:TextLabel.Content>
                        </controls:TextLabel>

                        <controls:BaseTextBox
                            x:Name="txtInput"
                            
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            
                            Grid.Row="1"
                            
                            OriginalValue=
                                "{Binding OriginalValue,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"
                            PlaceholderValue=
                                "{Binding PlaceholderValue,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"
                            ShowClear=
                                "{Binding ShowClear,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"
                            ShowCopy=
                                "{Binding ShowCopy,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"
                            ShowPlaceholder=
                                "{Binding ShowPlaceholder,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"
                            ShowRevert=
                                "{Binding ShowRevert,
                                          Mode=OneWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"
                            Text=
                                "{Binding Text,
                                          Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"
                            TextMargin=
                                "{Binding TextMargin,
                                          Mode=TwoWay,
                                          RelativeSource={RelativeSource AncestorType={x:Type controls:LabeledTextBox}}}"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        
                        <!-- Show Parts depending on state -->
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="txtLabel"
                                    Property="Visibility"
                                    Value="Hidden"/>
                        </Trigger>

                        <Trigger Property="Text" Value="">
                            <Setter TargetName="txtLabel"
                                    Property="Visibility"
                                    Value="Hidden"/>
                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="txtLabel"
                                    Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:SimplifiedTextBox}"
           BasedOn="{StaticResource TextBox_CommonStyle}">
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0 0 0 1"/>

        <Setter Property="MinHeight" Value="10"/>

        <Setter Property="ShowClear" Value="False"/>
        <Setter Property="ShowCopy" Value="False"/>
        <Setter Property="ShowPlaceholder" Value="True"/>
        <Setter Property="ShowRevert" Value="True"/>
