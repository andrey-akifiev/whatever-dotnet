<UserControl x:Class="WhateverDotNet.TestApp.Excel.Components.ReportSpecificationWorksheetDetails"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             xmlns:components="clr-namespace:WhateverDotNet.TestApp.Excel.Components"
             xmlns:controls="clr-namespace:WhateverDotNet.TestApp.Components.Controls;assembly=WhateverDotNet.TestApp.Components"
             xmlns:converters="clr-namespace:WhateverDotNet.TestApp.Components.Converters;assembly=WhateverDotNet.TestApp.Components"
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Excel.Components"
             xmlns:models="clr-namespace:WhateverDotNet.TestApp.Excel.Models"
             
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/TextBoxStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:EnumValueConverter x:Key="EnumValueConverter"/>

            <ObjectDataProvider 
                    x:Key="ColumnTypes"
                    MethodName="GetValues"
                    ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type Type="models:ReportSpecificationColumnTypes"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <StackPanel Orientation="Vertical">
        <TextBlock
            Margin="5"
            Text="ReportSpecificationWorksheetDetails"
            FontWeight="Bold"
            FontSize="14"/>
        <controls:ColoredExpanderPanel
            ColorMark="{DynamicResource Foreground_IconButton_HighlightedBrush}"
            IsExpanded="{Binding IsExpanded}"
            Margin="5">
            <controls:ColoredExpanderPanel.Header>
                <Grid HorizontalAlignment="Stretch" Focusable="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
        
                        FontFamily="{DynamicResource RegularFontFamily}"
                        FontSize="{DynamicResource RegularFontSize}"
                        FontStyle="Normal"
                        FontWeight="Normal"
        
                        Text="Worksheet: "
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis"/>
                    <TextBlock
                        Grid.Column="1"
        
                        FontFamily="{DynamicResource RegularFontFamily}"
                        FontSize="{DynamicResource RegularFontSize}"
                        FontStyle="Normal"
                        FontWeight="Normal"
        
                        Text="{Binding Title}"
                        TextWrapping="NoWrap"
                        TextTrimming="CharacterEllipsis"/>

                    <controls:TrashIconButton
                        Grid.Column="2"
                        Margin="5 0 5 0"
                        Size="14"/>
                    <controls:UndoIconButton
                        Grid.Column="3"
                        IsEnabled="{Binding IsDirty, Mode=OneWay}"
                        Margin="5 0 5 0"
                        Size="14"/>
                    <controls:SaveIconButton
                        Grid.Column="4"
                        IsEnabled="{Binding IsDirty, Mode=OneWay}"
                        Margin="5 0 5 0"
                        Size="14"/>
                </Grid>
            </controls:ColoredExpanderPanel.Header>
            <controls:ColoredExpanderPanel.Content>
                <DockPanel>
                    <!-- Main Properties -->
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="200"/>
                            <ColumnDefinition Width="*" MinWidth="200"/>
                        </Grid.ColumnDefinitions>

                        <TextBox
                            Grid.Column="0"
                            Grid.Row="0"
        
                            Margin="0 0 5 0"
        
                            Style="{StaticResource RegularTextBox}"
                            Tag="Name"
                            Text="{Binding Title}"/>

                        <TextBox
                            Grid.Column="1"
                            Grid.Row="0"
        
                            Margin="5 0 0 0"
        
                            Style="{StaticResource RegularTextBox}"
                            Tag="Description"
                            Text="{Binding Title}"/>
                    </Grid>

                    <!-- Columns -->
                    <components:ReportSpecificationColumnsDetails
                        DockPanel.Dock="Bottom"
                        DataContext="{Binding ColumnsViewModel}"/>
                </DockPanel>
            </controls:ColoredExpanderPanel.Content>
        </controls:ColoredExpanderPanel>
        
    </StackPanel>
</UserControl>