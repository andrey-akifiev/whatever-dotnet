<UserControl x:Class="WhateverDotNet.TestApp.Excel.Components.ReportSpecificationColumnsDetails"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             xmlns:controls="clr-namespace:WhateverDotNet.TestApp.Components.Controls;assembly=WhateverDotNet.TestApp.Components"
             xmlns:converters="clr-namespace:WhateverDotNet.TestApp.Components.Converters;assembly=WhateverDotNet.TestApp.Components"
             xmlns:dvms="clr-namespace:WhateverDotNet.TestApp.Excel.DesignData"
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Excel.Components"
             xmlns:models="clr-namespace:WhateverDotNet.TestApp.Excel.Models"
             xmlns:vms="clr-namespace:WhateverDotNet.TestApp.Excel.ViewModels"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type={x:Type dvms:DReportSpecificationColumnsDetailsViewModel}, IsDesignTimeCreatable=True}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:EnumValueConverter x:Key="EnumValueConverter"/>

            <ObjectDataProvider 
                    x:Key="ColumnTypes"
                    MethodName="GetValues"
                    ObjectType="{x:Type sys:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type Type="models:ReportSpecificationColumnTypes"/>
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel
            Background="{DynamicResource BackgroundRegularBrush}">
        <!-- Common Table Controls -->
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                
                FontSize="{DynamicResource RegularFontSize}"
                FontFamily="{DynamicResource RegularFontFamily}"
                Foreground="{DynamicResource ForegroundRegularBrush}"
                Margin="8"
                Text="Columns"/>

            <controls:AddIconButton
                Grid.Column="1"

                Content="Add Column"
                Command="{Binding AddRowCommand}"
                Margin="0 0 8 0"
                Size="14"/>
        </Grid>

        <DataGrid
            DockPanel.Dock="Bottom"
            ItemsSource="{Binding Rows}"
            PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown">

            <DataGrid.Resources>
                <DataTemplate x:Key="TypeDisplayTemplate">
                    <Grid>
                        <TextBlock
                            Style="{StaticResource EditableDataGrid_TextBlock_Style}"
                            Text="{Binding Type}"/>

                        <Border Grid.Column="1"
                            Grid.Row="0"
                        
                            Height="16"
                            Width="16"
                            Margin="0 0 6 0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                            <Path
                            Data="M0 0 16 16 0 0 8 11.207l-4-4V5.793l4 4 4-4v1.414 L8 11.207"
                            Fill="{StaticResource ForegroundRegularBrush}"

                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"

                            Stretch="Uniform"/>
                        </Border>
                    </Grid>
                </DataTemplate>

                <DataTemplate x:Key="TypeEditingTemplate">
                    <ComboBox 
                        IsDropDownOpen="True" 

                        ItemsSource="{Binding Source={StaticResource ColumnTypes}}"
                    
                        Style="{StaticResource EditableDataGrid_ComboBoxCell_EditingElementStyle}"
                        Text="{Binding Type,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                </DataTemplate>

                <Style x:Key="TextBoxDataGridStyle" TargetType="{x:Type TextBlock}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="FontFamily" Value="{DynamicResource RegularFontFamily}"/>
                    <Setter Property="FontSize" Value="{DynamicResource RegularFontSize}"/>
                </Style>

                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="FontFamily" Value="{DynamicResource RegularFontFamily}"/>
                    <Setter Property="FontSize" Value="{DynamicResource RegularFontSize}"/>
                    <Setter Property="FontStyle" Value="Normal"/>
                    <Setter Property="FontWeight" Value="Normal"/>

                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                                <Grid>
                                    <Border 
                                    BorderThickness="1"
                                    Padding="3 0 3 0">
                                        <ContentPresenter 
                                        HorizontalAlignment="Center"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type DataGridColumnHeadersPresenter}">
                    <Setter Property="Margin" Value="0 4 0 4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type DataGridColumnHeadersPresenter}">
                                <Grid>
                                    <DataGridColumnHeader IsHitTestVisible="False" />
                                    <ItemsPresenter />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type DataGrid}">
                    <Setter Property="AutoGenerateColumns" Value="False"/>

                    <Setter Property="Background" Value="{DynamicResource BackgroundRegularBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderRegularBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>

                    <Setter Property="CanUserAddRows" Value="False"/>
                    <Setter Property="CanUserDeleteRows" Value="False"/>
                    <Setter Property="CanUserReorderColumns" Value="False"/>
                    <Setter Property="CanUserResizeColumns" Value="False"/>
                    <Setter Property="CanUserResizeRows" Value="False"/>
                    <Setter Property="CanUserSortColumns" Value="False"/>

                    <Setter Property="Focusable" Value="False"/>

                    <Setter Property="GridLinesVisibility" Value="None"/>

                    <Setter Property="HeadersVisibility" Value="Column"/>
                    <Setter Property="IsReadOnly" Value="False"/>

                    <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
                    <Setter Property="ScrollViewer.PanningMode" Value="None"/>
                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>

                    <Setter Property="SelectionMode" Value="Single"/>
                    <Setter Property="SelectionUnit" Value="Cell"/>


                </Style>
            </DataGrid.Resources>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Background" Value="Transparent"/>

                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>

                        <Trigger Property="IsEditing" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn
                    Header="Name"
                    Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type vms:ReportSpecificationColumnDetailsViewModel}">
                            <controls:SimplifiedTextBlock
                                FontSize="{DynamicResource FontSize_Small}"
                                Text="{Binding Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate DataType="{x:Type vms:ReportSpecificationColumnDetailsViewModel}">
                            <controls:SimplifiedTextBox
                                FontSize="{DynamicResource FontSize_Small}"
                                OriginalValue="{Binding NameOriginal}"
                                PlaceholderValue="Name"
                                Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn
                    Header="Display Name"
                    Binding="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Width="*"
                    EditingElementStyle="{StaticResource EditableDataGrid_TextBox_Style}"
                    ElementStyle="{StaticResource EditableDataGrid_TextBlock_Style}"/>

                <DataGridTemplateColumn
                    Header="Type"
                    Width="*"
                    CellTemplate="{StaticResource TypeDisplayTemplate}"
                    CellEditingTemplate="{StaticResource TypeEditingTemplate}"/>

                <DataGridCheckBoxColumn
                    Header="Valuable"
                    Width="*"/>
                <DataGridCheckBoxColumn
                    Header="Comparable"
                    Width="*"/>
                <DataGridTemplateColumn
                    Header=""
                    Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <controls:CopyIconButton
                                    Command="{Binding CloneCommand}"
                                    Margin="2 0 2 0"
                                    Size="14"/>
                                <controls:UndoIconButton
                                    Command="{Binding RevertCommand}"
                                    Margin="2 0 2 0"
                                    Size="14"/>
                                <controls:TrashIconButton
                                    Command="{Binding DeleteCommand}"
                                    Margin="2 0 2 0"
                                    Size="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
