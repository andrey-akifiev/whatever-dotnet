<UserControl x:Class="WhateverDotNet.TestApp.Excel.Views.ReportSpecificationsView"
             x:Name="root"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             xmlns:controls="clr-namespace:WhateverDotNet.TestApp.Components.Controls;assembly=WhateverDotNet.TestApp.Components"
             xmlns:components="clr-namespace:WhateverDotNet.TestApp.Excel.Components"
             xmlns:local="clr-namespace:WhateverDotNet.TestApp.Excel.Views"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Page Title -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource BackgroundContrastBrush}"
                BorderThickness="0 0 0 2">
            <StackPanel
                    Orientation="Horizontal">
                <Path Data="{Binding Icon}"
                      Fill="{DynamicResource BackgroundContrastBrush}"
                      Height="24"
                      Margin="20 10 0 0"
                      Width="24"/>
                <TextBlock
                    FontFamily="{DynamicResource RegularFontFamily}"
                    FontSize="{DynamicResource PageNameFontSize}"
    
                    Margin="10, 20, 0, 10"
                    Text="Report Specifications"/>
            </StackPanel>
        </Border>
        <!-- Page Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding Listing.MenuWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:ListingPanel
                Grid.Column="0"
                        
                DataContext="{Binding Listing}"/>
            <components:ReportSpecificationDetails 
                Grid.Column="1"
                Grid.Row="0"
                Grid.RowSpan="2"
                        
                Margin="20 15 5 0"
                        
                DataContext="{Binding Details}" />
        </Grid>
    </Grid>
</UserControl>
