<UserControl x:Class="WhateverDotNet.TestApp.Excel.Views.MainView"
             x:Name="root"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:components="clr-namespace:WhateverDotNet.TestApp.Excel.Components"
             xmlns:controls="clr-namespace:WhateverDotNet.TestApp.Components.Controls;assembly=WhateverDotNet.TestApp.Components"
             xmlns:converters="clr-namespace:WhateverDotNet.TestApp.Components.Converters;assembly=WhateverDotNet.TestApp.Components"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dvms="clr-namespace:WhateverDotNet.TestApp.Excel.DesignData"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:pages="clr-namespace:WhateverDotNet.TestApp.Excel.Pages.ReportSpecifications"
             xmlns:views="clr-namespace:WhateverDotNet.TestApp.Excel.Views"
             xmlns:vm="clr-namespace:WhateverDotNet.TestApp.Excel.ViewModels"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type={x:Type dvms:DReportSpecificationColumnsDetailsViewModel}, IsDesignTimeCreatable=True}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/WhateverDotNet.TestApp.Components;component/Assets/Styles/Basics.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type pages:ReportSpecificationsViewModel}">
                <views:ReportSpecificationsView />
            </DataTemplate>

            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding MenuViewModel.MenuWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Main content area with navigation sidebar -->
        <controls:HamburgerMenu Grid.Column="0"
                            Background="{DynamicResource BackgroundContrastBrush}"
                            Foreground="{DynamicResource ForegroundWhiteBrush}"
                             DataContext="{Binding MenuViewModel}"/>
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"/>

        <!-- Modal overlay placeholder; will be wired later -->
        <!--<Grid Grid.RowSpan="2"
              Background="#80000000"
              Visibility="{Binding IsModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ContentControl HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="400"
                            Background="White"
                            Padding="20"
                            Content="{Binding CurrentModalViewModel}" />
        </Grid>-->
    </Grid>
</UserControl>

